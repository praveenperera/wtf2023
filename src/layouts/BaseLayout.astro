---
import Header from "@/components/Header.astro";
import "@/styles/global.css";

type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogImageWidth?: string;
  ogImageHeight?: string;
};

const {
  title = "WTF Happened in Feb 2023?",
  description = "A chart-led explainer about Bitcoin spam, blockspace pressure, and February 2023",
  ogImage,
  ogImageAlt,
  ogImageWidth = "1200",
  ogImageHeight = "630",
} = Astro.props;
const siteName = "WTF Happened in Feb 2023?";
const canonicalUrl = Astro.url.href;
const ogImageUrl = new URL(ogImage ?? "/og/home.png", Astro.url).href;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    <meta property="og:image:width" content={ogImageWidth} />
    <meta property="og:image:height" content={ogImageHeight} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}
    <meta name="twitter:image:width" content={ogImageWidth} />
    <meta name="twitter:image:height" content={ogImageHeight} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const theme = stored || "dark";
        document.documentElement.classList.toggle("dark", theme === "dark");
      })();
    </script>
    <script is:inline>
      (() => {
        const scrollToHash = () => {
          const id = decodeURIComponent(window.location.hash.slice(1));
          const target = id ? document.getElementById(id) : null;

          if (target) {
            target.scrollIntoView({ block: "start" });
          }
        };

        window.addEventListener("load", () => {
          requestAnimationFrame(scrollToHash);
          window.setTimeout(scrollToHash, 250);
          window.setTimeout(scrollToHash, 900);
        });
      })();
    </script>
  </head>
  <body>
    <Header />
    <slot />
  </body>
</html>
