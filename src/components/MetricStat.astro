---
type Props = {
  label: string;
  value: string;
  unit?: string;
  source: string;
  tone?: "accent" | "payment" | "utxo" | "risk";
};

const { label, value, unit, source, tone = "accent" } = Astro.props;
const toneClass = {
  accent: "text-accent",
  payment: "text-payment",
  utxo: "text-utxo",
  risk: "text-risk",
}[tone];
---

<div class="data-panel grid h-full min-h-36 content-between gap-5 p-4 sm:p-5">
  <dt
    class="text-xs font-medium uppercase leading-5 tracking-[0.18em] text-dim"
  >
    {label}
  </dt>
  <dd
    class={`flex items-baseline gap-1 font-mono text-3xl font-semibold leading-none ${toneClass}`}
  >
    {value}{unit && <span class="text-sm text-muted">{unit}</span>}
  </dd>
  <dd class="border-t border-border/80 pt-3 text-xs leading-5 text-muted">
    {source}
  </dd>
</div>
