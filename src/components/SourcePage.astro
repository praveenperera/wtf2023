---
import { extractResourceItems, type RouteContent } from "@/lib/content";
import CurrentDamageSnapshot from "@/components/CurrentDamageSnapshot.astro";
import ReceiptCard from "@/components/ReceiptCard.astro";
import { narrativeReceipts } from "@/data/narrative-receipts";
import {
  ArrowUpRight,
  Check,
  CheckCircle2,
  Copy,
  Crosshair,
  ExternalLink,
  GitBranch,
  Info,
  Layers,
  Link as LinkIcon,
  Server,
  Terminal,
} from "lucide-react";

type Props = {
  content: RouteContent;
};

const { content } = Astro.props;
const isResources = content.id === "resources";
const resourceItems = isResources
  ? extractResourceItems(content.documents[0])
  : [];
const groupedResources = Object.entries(
  resourceItems.reduce<Record<string, typeof resourceItems>>((groups, item) => {
    groups[item.group] = [...(groups[item.group] ?? []), item];
    return groups;
  }, {}),
);
const mediaItems = isResources
  ? content.documents.flatMap((document) => document.media)
  : [];
const sectionDocuments =
  content.id === "narratives" ? content.documents.slice(1) : content.documents;
const contentSections = sectionDocuments.flatMap((document) =>
  document.sections.map((section) => ({
    ...section,
    documentTitle: document.title,
  })),
);
const actionOverviewDocument =
  content.id === "actions" ? content.documents[0] : undefined;
const actionRoleDocuments =
  content.id === "actions" ? content.documents.slice(1) : [];
const hasSectionNav = contentSections.length > 2;
const sectionCount = contentSections.length;
const showSourceRailStats = sectionCount > 1 || content.documents.length > 1;
const hasUsefulAside =
  isResources ||
  (content.id !== "actions" && (hasSectionNav || showSourceRailStats));
const routeClass = `source-page-${content.id}`;
const sourceVisualsByRoute: Partial<
  Record<
    RouteContent["id"],
    Array<{
      label: string;
      title: string;
      body: string;
      value: string;
      tone: "accent" | "payment" | "utxo" | "risk" | "purple";
    }>
  >
> = {
  impact: [
    {
      label: "Blockspace",
      title: "Monetary and non-monetary uses compete in one block auction",
      body: "Compare fee pressure, blockspace share, and UTXO pressure in the overview charts",
      value: "shared market",
      tone: "accent",
    },
    {
      label: "Fees",
      title:
        "Users making monetary transactions still had to clear higher fee pressure",
      body: "The charts make the fee-pressure trend visible without overstating precision",
      value: "fee trend",
      tone: "payment",
    },
    {
      label: "Nodes",
      title: "Long-lived outputs raise validation and storage costs",
      body: "The UTXO series tracks long-lived validation and storage pressure",
      value: "UTXO set",
      tone: "utxo",
    },
  ],
  characteristics: [
    {
      label: "Resource use",
      title: "Wasteful shared-resource demand",
      body: "Consumes scarce shared blockspace with little or no corresponding monetary value",
      value: "signal 1",
      tone: "accent",
    },
    {
      label: "Function fit",
      title: "Misuse of Bitcoin's functions",
      body: "Uses neutral transaction features in service of a malicious or harmful objective",
      value: "signal 2",
      tone: "payment",
    },
  ],
  narratives: [
    {
      label: "Policy",
      title: "Relay policy is local behavior, not a consensus rule",
      body: "Narrative cards compare claims against dated evidence",
      value: "local choice",
      tone: "utxo",
    },
    {
      label: "Validity",
      title: "A transaction can be valid and still be filtered by a node",
      body: "The page keeps the distinction visible through structured rebuttal sections",
      value: "two layers",
      tone: "accent",
    },
    {
      label: "Incentives",
      title: "Miner incentives do not remove user policy choices",
      body: "The page favors explicit argument maps over decorative media links",
      value: "tradeoff",
      tone: "purple",
    },
  ],
  actions: [
    {
      label: "Node runners",
      title: "Choose relay policy and software defaults intentionally",
      body: "Role cards keep commands and choices on-page without external media wrappers",
      value: "filter",
      tone: "utxo",
    },
    {
      label: "Miners",
      title: "Select templates and submission paths that match your policy",
      body: "The page leads with direct actions and supporting context",
      value: "template",
      tone: "accent",
    },
    {
      label: "Developers",
      title: "Improve defaults, docs, and review paths where policy lives",
      body: "Configuration details stay searchable and easy to apply",
      value: "defaults",
      tone: "payment",
    },
  ],
  core: [
    {
      label: "PR 29187",
      title:
        "The dispute centered on whether existing limits covered new data paths",
      body: "A compact issue map connects the policy gap to user costs",
      value: "policy gap",
      tone: "risk",
    },
    {
      label: "Docs",
      title: "Documentation changes can redefine how a limit is understood",
      body: "The page follows the claim trail through dated article sections",
      value: "meaning",
      tone: "accent",
    },
    {
      label: "Review",
      title: "The review question is about defaults, limits, and user cost",
      body: "Summary panels keep defaults, limits, and user costs connected",
      value: "cost",
      tone: "utxo",
    },
  ],
  history: [
    {
      label: "Relay",
      title: "Free relay has repeatedly created room for non-monetary pressure",
      body: "Timeline context highlights recurring relay-pressure patterns",
      value: "recurring",
      tone: "accent",
    },
    {
      label: "Private paths",
      title: "Direct-to-miner submission changes what public relay can observe",
      body: "The page separates public relay from direct submission paths",
      value: "out of band",
      tone: "purple",
    },
    {
      label: "Earlier cases",
      title:
        "Older abuse cases help separate consensus bugs from policy pressure",
      body: "The history page stays self-contained with concise explanation panels",
      value: "precedent",
      tone: "risk",
    },
  ],
};
const sourceVisuals = sourceVisualsByRoute[content.id] ?? [];
const historyTimelineDates: Record<string, string> = {
  "Free relays > Whitelists > Free relays": "Early Bitcoin relay policy",
  "The rise of out-of-band transactions": "February 22, 2024",
  "Noteworthy cases of massive broadcasts of non-monetary TXs": "2010-2019",
};
const characteristicsSections =
  content.id === "characteristics" && contentSections[0]
    ? buildCharacteristicsSections(contentSections[0].html)
    : [];
const nodeRunnerDocument = actionRoleDocuments.find((document) =>
  document.path.endsWith("/as-a-noderunner.md"),
);
const nodeRunnerSection = nodeRunnerDocument?.sections[0];
const actionRoleDocumentsAfterNodeRunner = actionRoleDocuments.filter(
  (document) => document !== nodeRunnerDocument,
);
const actionLevers = [
  {
    role: "Node runner",
    action: "Run filtering policy",
    detail: "Use Knots and explicit relay settings instead of passive defaults",
  },
  {
    role: "Miner",
    action: "Choose templates",
    detail:
      "Point hash rate at OCEAN, DATUM, or templates matching your policy",
  },
  {
    role: "Developer",
    action: "Review defaults",
    detail:
      "Contribute where policy, docs, and implementation choices are made",
  },
  {
    role: "Pleb",
    action: "Share evidence",
    detail:
      "Frame this as mitigation and rate limiting, not perfect prevention",
  },
] as const;
const strictRelayConfig = "permitbaremultisig=0\ndatacarrier=0";
const receiptClipSlots: Array<{
  title?: string;
  speaker?: string;
  exactQuote?: string;
  timestamp?: string;
  sourceUrl?: string;
  whyItMatters?: string;
}> = [];
const completeReceiptClips = receiptClipSlots.filter(
  (slot) =>
    slot.title &&
    slot.speaker &&
    slot.exactQuote &&
    slot.timestamp &&
    slot.sourceUrl &&
    slot.whyItMatters,
);

