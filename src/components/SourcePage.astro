function buildCharacteristicsSections(html: string) {
  const orderedList = html.match(/<ol>[\s\S]*?<\/ol>/);
  const orderedListStart = orderedList?.index;
  if (!orderedList || orderedListStart === undefined) return [];

  const intro = html.slice(0, orderedListStart).trim();
  const signalList = orderedList[0].replace(
    "<ol>",
    '<ol class="source-inline-signals">',
  );
  const afterList = html.slice(orderedListStart + orderedList[0].length).trim();
  const blocks =
    afterList.match(
      /(?:<p>[\s\S]*?<\/p>|<blockquote>[\s\S]*?<\/blockquote>)/g,
    ) ?? [];

  if (!intro || blocks.length < 7) return [];

  return [
    {
      title: "Recognition vs subjectivity",
      label: "Framing",
      bodyHtml: `${intro}${signalList}`,
      evidenceHtml:
        "<blockquote><p>spam can also be recognized by anyone, even intellectually honest spammers</p></blockquote><p>Recognition test</p>",
      tone: "accent",
    },
    {
      title: "Wastefulness of shared resources",
      label: "Signal 1",
      bodyHtml: blocks[0],
      evidenceHtml: blocks.slice(1, 3).join(""),
      tone: "payment",
    },
    {
      title: "Misuse of Bitcoin's functions",
      label: "Signal 2",
      bodyHtml: blocks[3],
      evidenceHtml: blocks.slice(4, 6).join(""),
      tone: "utxo",
    },
    {
      title: "Boundary cases",
      label: "Non-spam use",
      bodyHtml: blocks[6],
      evidenceHtml:
        "<blockquote><p>it uses shared resources efficiently and does not misuse Bitcoin's functions</p></blockquote><p>Boundary test</p>",
      tone: "accent",
    },
  ];
}
---

<main class:list={["source-page", routeClass]}>
  <section class="source-masthead border-b border-border py-10 md:py-16">
    <div
      class="mx-auto grid max-w-[94rem] gap-8 px-4 sm:px-6 lg:grid-cols-[minmax(0,0.95fr)_minmax(20rem,0.8fr)] lg:px-8"
    >
      <div class="source-masthead-title">
        <p class="source-kicker">{content.label}</p>
        <h1 class="source-title">{content.documents[0].title}</h1>
        {
          content.id === "characteristics" ? (
            <div class="source-title-copy">
              <p class="source-takeaway-text">{content.takeaway}</p>
              <p>{content.summary}</p>
            </div>
          ) : null
        }
      </div>
      <div class="source-takeaway self-end">
        {
          content.id === "impact" && sourceVisuals.length ? (
            <section class="source-hero-panel source-glance-panel">
              <h2>At a glance</h2>
              <div>
                {sourceVisuals.map((visual) => (
                  <p
                    class:list={[
                      "source-glance-row",
                      `source-glance-${visual.tone}`,
                    ]}
                  >
                    <span>{visual.value}</span>
                    {visual.title}
                  </p>
                ))}
              </div>
            </section>
          ) : null
        }
        {
          content.id === "characteristics" && sourceVisuals.length ? (
            <section class="source-hero-panel source-model-panel">
              <h2>Two-part recognition model</h2>
              <div class="source-model-list">
                {sourceVisuals.map((visual, index) => (
                  <article
                    class:list={[
                      "source-model-row",
                      `source-model-${visual.tone}`,
                    ]}
                  >
                    <span class="source-model-index">{index + 1}</span>
                    <span class="source-model-icon" aria-hidden="true">
                      {index === 0 ? (
                        <Layers size={31} strokeWidth={2.1} />
                      ) : (
                        <Crosshair size={31} strokeWidth={2.1} />
                      )}
                    </span>
                    <div>
                      <p>{visual.title}</p>
                      <small>{visual.body}</small>
                    </div>
                    <span class="source-model-check" aria-hidden="true">
                      <Check size={20} strokeWidth={3} />
                    </span>
                  </article>
                ))}
              </div>
              <p class="source-model-result">
                <span>Both present</span>
                The activity is spam
              </p>
            </section>
          ) : null
        }
        {
          content.id !== "characteristics" ? (
            <>
              <div>
                <p class="source-takeaway-label">Takeaway</p>
                <p class="source-takeaway-text">{content.takeaway}</p>
              </div>
              <div class="source-summary">
                <p class="source-takeaway-label">Summary</p>
                <p>{content.summary}</p>
              </div>
            </>
          ) : null
        }
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16">
    <div
      class:list={[
        "source-body-grid mx-auto grid max-w-[94rem] gap-10 px-4 sm:px-6 lg:px-8",
        hasUsefulAside ? "source-body-grid-aside" : "",
      ]}
    >
      {
        isResources ? (
          <article class="source-library min-w-0">
            <div class="source-library-header">
              <div>
                <h2>Resource library</h2>
                <p>
                  Articles, podcasts, papers, and clips grouped by how someone
                  would actually use them.
                </p>
              </div>
              <span class="source-count">
                {resourceItems.length + mediaItems.length} items
              </span>
            </div>

            <div class="source-shelves">
              {groupedResources.map(([group, items]) => (
                <section
                  class="source-shelf"
                  id={group.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}
                >
                  <div class="source-shelf-heading">
                    <h3>{group}</h3>
                    <span>{items.length} links</span>
                  </div>
                  <div class="source-link-list">
                    {items.map((item) => (
                      <a class="source-link-row" href={item.href}>
                        <span
                          class:list={[
                            "source-type",
                            `source-type-${item.type}`,
                          ]}
                        >
                          {item.type}
                        </span>
                        <span class="source-link-copy">
                          <span>{item.title}</span>
                          {item.note ? <span>{item.note}</span> : null}
                        </span>
                        <span class="source-link-arrow" aria-hidden="true">
                          <ArrowUpRight size={16} strokeWidth={2} />
                        </span>
                      </a>
                    ))}
                  </div>
                </section>
              ))}

              {mediaItems.length ? (
                <section class="source-shelf" id="media">
